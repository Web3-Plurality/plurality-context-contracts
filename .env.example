# Wallet that deploys the contracts. Must hold TEST ROSE on Sapphire testnet.
# Faucet: https://faucet.testnet.oasis.io/
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Optional: address of the backend signer wallet that will register context
# hashes on-chain. Granted REGISTRAR_ROLE during deploy when set and distinct
# from the deployer. For the new market stack, this is the address derived
# from plurality-market-backend's BACKEND_WALLET_PRIVATE_KEY.
BACKEND_WALLET_ADDRESS=
